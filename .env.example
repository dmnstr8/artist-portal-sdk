# APP_API_KEY: Optional API key for external integrations.
APP_API_KEY="MY_APP_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Cloud deployment target for the client (optional). production | release
# Implemented as VITE_FIREBASE_TARGET. If unset, Vite mode decides:
# `vite build --mode release` → release; default `vite build` / `vite dev` → production.
# VITE_FIREBASE_TARGET=release

# Optional URL path segment inserted after Vite BASE_URL for asset paths.
# Example: VITE_HOST_BASE=media -> asset URLs become /media/...
# VITE_HOST_BASE=home/www

