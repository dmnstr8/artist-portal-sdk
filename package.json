{
  "name": "artist-portal-sdk",
  "private": true,
  "version": "0.1.3",
  "type": "module",
  "packageManager": "pnpm@8.14.1",
  "scripts": {
    "build:sdk": "pnpm --filter @dmnstr8/artist-portal-sdk run build",
    "build:sdk:dev": "pnpm --filter @dmnstr8/artist-portal-sdk run build && pnpm --filter sdk-example run build",
    "build:sdk:release": "pnpm --filter @dmnstr8/artist-portal-sdk run build && pnpm --filter sdk-example run build:release",
    "dev:sdk:dev": "pnpm --filter sdk-example run dev",
    "dev:sdk:release": "pnpm --filter sdk-example run dev:release",
    "clean": "node scripts/clean-docs.mjs",
    "sync:public-assets": "node scripts/sync-public-assets.mjs",
    "lint": "pnpm run build:sdk && pnpm --filter client-theschneiderhair run lint",
    "seed:videolinks": "node scripts/seed-videolinks-firestore.mjs",

    "deploy:rules": "pnpm run deploy:rules:production",
    "deploy:rules:production": "firebase deploy --only firestore:rules -P production",
    "deploy:rules:release": "firebase deploy --only firestore:rules -P release",
    "deploy:hosting:production": "pnpm run build:production && firebase deploy --only hosting -P production",
    "deploy:hosting:release": "pnpm run build:release && firebase deploy --only hosting -P release",
    "deploy:live": "pnpm run deploy:hosting:release"

  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@dmnstr8/artist-portal-sdk": "workspace:*",
    "firebase": "^12.12.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@tailwindcss/oxide-win32-x64-msvc": "^4.2.4",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "firebase-admin": "^13.8.0",
    "firebase-tools": "^15.15.0",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
