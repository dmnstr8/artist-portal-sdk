rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.admin == true ||
        request.auth.token.email in [
          "diggs.it.accnt@gmail.com"
        ]
      );
    }

    match /{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && request.resource.size <= 25 * 1024 * 1024;
    }
  }
}
